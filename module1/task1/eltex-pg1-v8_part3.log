mkdir -p D1/D2/D3
touch D1/D2/file.txt
echo 'test text' > D1/D2/file.txt
ln -s ../file.txt D1/D2/D3/file_sym.txt
ln D1/D2/file.txt D1/D2/D3/file_hard.txt
ls -li D1/D2/file.txt D1/D2/D3/file_sym.txt D1/D2/D3/file_hard.txt
cat D1/D2/D3/file_sym.txt D1/D2/D3/file_hard.txt
mv D1/D2/file.txt D1/file.txt
cat D1/D2/D3/file_sym.txt
cat D1/D2/D3/file_hard.txt
rm -r D1/D2
find / -type f -size +20M 2>/dev/null > "${USER}_part3_gt50M.log"
while IFS= read -r f; do du -h "$f"; done < "${USER}_part3_gt50M.log"
find ~ -type f -mtime -1
which find
file "$(which find)"
file /boot/initrd.img*
