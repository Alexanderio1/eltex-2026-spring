root@eltex-practice2-pg1-v8:~# awk '
> {
>     line=$0
>     sub(/^[A-Z][a-z]{2} [ 0-9][0-9] [0-9:]{8} [^ ]+ /, "", line)
>     sub(/^[0-9T:+.-]+ [^ ]+ /, "", line)
> 
>     src=line
>     sub(/: .*/, "", src)
> 
>     msg=line
>     sub(/^[^:]+: /, "", msg)
> 
>     print src "\t" msg
> }' "$AUTHLOG" | sed -E 's/\[[0-9]+\]//g' | sort -k1,1
