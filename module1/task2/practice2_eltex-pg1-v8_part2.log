> while IFS=: read -r user uid gid; do
> primary=$(awk -F: -v gid="$gid" '$3==gid{print $1}' /etc/group)
> other=$(awk -F: -v u="$user" '$4 ~ "(^|,)" u "(,|$)" {print $1}' /etc/group | paste -sd, -)
> groups="$primary"
> [ -n "$other" ] && [ "$other" != "$primary" ] && groups="$groups,$other"
